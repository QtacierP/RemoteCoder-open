TELEGRAM_BOT_TOKEN=replace_with_bot_token
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_PATH=./data/bridge.db
LOG_DIR=./logs
CONVERSATION_HISTORY_DIR=./history_conversations
DEFAULT_CODEX_MODE=codex_cli_session
DEFAULT_WORKSPACE=/workspace
ALLOWED_WORKSPACES=
CODEX_BIN=codex
CODEX_CLI_ARGS=-a never --sandbox workspace-write
CODEX_MESSAGE_TIMEOUT_SECONDS=120
CODEX_DEBUG_MODE=false
SHARED_PROXY_URL=
SHARED_PROXY_PORT=0
SHARED_PROXY_SCHEME=socks5h
TELEGRAM_POLL_INTERVAL_SECONDS=1.5
TELEGRAM_LONG_MESSAGE_CHUNK=3500
TELEGRAM_DEBUG_MODE=false
